# ── Standalone mode ────────────────────────────────────────────────
# URL of the YourFinanceWORKS instance this plugin connects to
INVOICE_API_URL=http://localhost:8000

# API key generated in YFW: Settings → API Access → Create Key
INVOICE_API_KEY=ak_your_key_here

# Secret key for JWT signing (standalone only)
SECRET_KEY=change-me-in-production

# ── Optional database (for file metadata / caching) ────────────────
# Leave blank to run fully stateless
DATABASE_URL=

# ── Optional cloud storage ─────────────────────────────────────────
# Backends: none | s3 | azure | gcs   (default: none = direct browser download)
STORAGE_BACKEND=none
FILE_RETENTION_DAYS=7

# AWS S3
AWS_S3_BUCKET=
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_REGION=us-east-1

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER=

# Google Cloud Storage
GCP_BUCKET_NAME=
GCP_CREDENTIALS_JSON=

# ── Server ─────────────────────────────────────────────────────────
API_PORT=8000
UI_PORT=3000
